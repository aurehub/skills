# xaut-trade runtime variables template (safe to commit)
# Copy to ~/.aurehub/.env and fill in real values. Never put sensitive data in this file.

# Required: Ethereum mainnet RPC
ETH_RPC_URL=https://eth.llamarpc.com
# Fallback RPCs tried in order when primary fails with a network error (429/502/timeout)
# Add a paid Alchemy/Infura node at the front for higher reliability
ETH_RPC_URL_FALLBACK=https://ethereum.publicnode.com,https://rpc.flashbots.net/fast,https://1rpc.io/eth

# Recommended: Foundry keystore account name (set automatically by onboarding)
FOUNDRY_ACCOUNT=aurehub-wallet

# Keystore password file path (required when using FOUNDRY_ACCOUNT)
KEYSTORE_PASSWORD_FILE=~/.aurehub/.wallet.password

# Fallback: private key mode (not recommended)
# PRIVATE_KEY=0x...

# Required for limit orders: UniswapX API Key
# Apply (free): https://developers.uniswap.org/dashboard → sign in → create API key
# Not needed for market orders
UNISWAPX_API_KEY=your_api_key_here

# Optional: activity rankings (opt-in, set during setup)
# RANKINGS_OPT_IN=false
# NICKNAME=YourName
