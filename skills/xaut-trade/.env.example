# xaut-trade 运行时变量模板（可提交）
# 复制为 ~/.aurehub/.env 后填写真实值，本文件禁止放敏感真实数据。

# 必填：Ethereum 主网 RPC
ETH_RPC_URL=https://eth.llamarpc.com

# 推荐：使用 Foundry keystore 账户名（由 onboarding 自动配置）
FOUNDRY_ACCOUNT=aurehub-wallet

# keystore 密码文件路径（使用 FOUNDRY_ACCOUNT 时必填）
KEYSTORE_PASSWORD_FILE=~/.aurehub/.wallet.password

# 兼容：私钥模式（降级方案，不推荐）
# PRIVATE_KEY=0x...

# 限价单必填：UniswapX API Key
# 申请（约 5 分钟，免费）：https://portal.1inch.dev → 登录 → 生成 Token
# 市价单不需要此配置
UNISWAPX_API_KEY=your_api_key_here
