# Wallet configuration shared with other aurehub skills
# Copy this file to ~/.aurehub/.env if it doesn't exist

WALLET_MODE=               # wdk (recommended) or foundry
WDK_PASSWORD_FILE=~/.aurehub/.wdk_password
# WDK_VAULT_FILE=~/.aurehub/.wdk_vault    # optional, this is the default
# FOUNDRY_ACCOUNT=aurehub-wallet          # required if WALLET_MODE=foundry
# KEYSTORE_PASSWORD_FILE=~/.aurehub/.wallet.password
